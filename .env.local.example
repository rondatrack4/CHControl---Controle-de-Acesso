# ==========================================================================
# CHControl - variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores do seu projeto
# Supabase (local via `supabase start` ou um projeto no Supabase Cloud).
# ==========================================================================

# URL pública do projeto Supabase
# Local (supabase CLI): http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Chave anônima (anon/publishable). Usada no browser + SSR.
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloque-a-anon-key-aqui

# Chave service_role (NUNCA exposta ao browser). Usada apenas em
# rotas de servidor privilegiadas (ex.: criar empresa + 1º porteiro).
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui
