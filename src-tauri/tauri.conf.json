{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CHControl",
  "version": "0.1.0",
  "identifier": "dev.chcontrol.desktop",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "updater": {
    "active": true,
    "endpoints": [
      "https://releases.githubusercontent.com/repos/rondatrack4/CHControl---Controle-de-Acesso/releases/download/v{{current_version}}/latest.json"
    ],
    "dialog": true,
    "pubkey": ""
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": {
      "resources/server": "server",
      "resources/node": "node"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
