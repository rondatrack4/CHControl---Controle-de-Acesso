{
  "name": "chcontrol",
  "version": "1.0.0",
  "private": true,
  "description": "CHControl - Sistema SaaS multi-tenant de controle de acesso para condomínios",
  "scripts": {
    "dev": "next dev",
    "dev:desktop": "cross-env APP_MODE=desktop NEXT_PUBLIC_APP_MODE=desktop next dev -p 3010",
    "start:desktop": "cross-env APP_MODE=desktop NEXT_PUBLIC_APP_MODE=desktop next start -p 3010",
    "prod:desktop": "cross-env APP_MODE=desktop NEXT_PUBLIC_APP_MODE=desktop next build && npm run start:desktop",
    "db:migrate": "cross-env APP_DATA_DIR=\"%APPDATA%/CHControl\" node scripts/run-migrations.mjs",
    "build:desktop": "node scripts/build-desktop.mjs",
    "tauri:build": "tauri build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.469.0",
    "next": "15.1.3",
    "next-themes": "^0.4.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
